    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/js/terminal.js"></script>
    <script>
      // Inicialización de AOS con tus parámetros originales
      AOS.init({
        duration: 800,
        easing: "ease-out-cubic",
        once: true,
        offset: 100,
      });

      // Helper para simular pausas sutiles y dar fluidez visual a la terminal
      const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

      // Función para copiar la salida JSON de las consolas al portapapeles
      function copyConsole(id) {
        const text = document.getElementById(id).innerText;
        if (!text || text.trim() === "") return;
        navigator.clipboard.writeText(text).then(() => {
          alert("¡Respuesta copiada al portapapeles!");
        });
      }

      // ==========================================
      // 1. ENVÍO ASÍNCRONO DEL FORMULARIO DE CONTACTO (SQLite)
      // ==========================================
      async function submitForm(event) {
        event.preventDefault();

        const name = document.getElementById("form-name").value;
        const email = document.getElementById("form-email").value;
        const message = document.getElementById("form-message").value;

        const btn = document.getElementById("submit-btn");
        const btnText = document.getElementById("btn-text");
        const statusDiv = document.getElementById("form-status");

        // Cambiar botón a estado de carga
        btn.disabled = true;
        btnText.innerText = "Guardando en SQLite...";
        statusDiv.classList.add("hidden");

        try {
          const response = await fetch("/api/v1/contacto", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name, email, message }),
          });

          const data = await response.json();

          if (response.ok) {
            statusDiv.className =
              "text-xs text-center font-medium mt-4 p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400";
            statusDiv.innerHTML = `✅ ${data.msg}`;
            document.getElementById("contactForm").reset();
          } else {
            throw new Error(data.msg || "Error al procesar la solicitud.");
          }
        } catch (error) {
          statusDiv.className =
            "text-xs text-center font-medium mt-4 p-3 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400";
          statusDiv.innerHTML = `❌ Error: ${error.message}`;
        } finally {
          statusDiv.classList.remove("hidden");
          btn.disabled = false;
          btnText.innerText = "Enviar Mensaje";
        }
      }

      // ==========================================
      // 2. SOLICITUDES FETCH REALES HACIA TUS ENDPOINTS MVC + INTERFAZ DINÁMICA
      // ==========================================
      async function testAPI(type, btn) {
        const originalContent = btn.innerHTML;
        btn.disabled = true;

        // Capturar contenedores del DOM correspondientes al tipo de acción
        const container = document.getElementById(`res-container-${type}`);
        const consoleElem = document.getElementById(`res-${type}`);

        // Mostrar la terminal en pantalla y limpiar contenido previo
        container.classList.remove("hidden");
        consoleElem.className = `p-3 h-32 overflow-y-auto whitespace-pre-wrap text-${type === "scan" ? "cyan" : type === "auth" ? "indigo" : "emerald"}-400/90`;
        consoleElem.innerText = "";

        // Configuración por defecto para la consulta Fetch
        let url = "/api/v1/health-check";
        let options = { method: "GET" };

        try {
          // --- ESCÁNER DE PUERTOS (POST) ---
          if (type === "scan") {
            btn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> Escaneando...`;
            const host =
              document.getElementById("scan-host").value || "127.0.0.1";

            consoleElem.innerText = `[+] Inicializando socket TCP/IP...\n`;
            await sleep(400);
            consoleElem.append(`[i] Target asignado: ${host}\n`);
            await sleep(500);
            consoleElem.append(`[+] Escaneando puertos bien conocidos...\n`);

            url = "/api/v1/scan";
            options = {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ host: host }),
            };
          }
          // --- GENERADOR DE TOKENS (POST) ---
          else if (type === "auth") {
            btn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> Firmando...`;
            const role = document.getElementById("token-role").value;

            consoleElem.innerText = `[+] Inicializando proveedor de firmas criptográficas...\n`;
            await sleep(400);
            consoleElem.append(
              `[i] Cargando claims de autorización [Rol: ${role}]...\n`,
            );
            await sleep(500);

            url = "/api/v1/auth/token";
            options = {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ role: role }), // Enviamos el rol seleccionado al backend
            };
          }
          // --- MONITOREO DE SISTEMA (GET) ---
          else if (type === "health") {
            btn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> Consultando...`;
            consoleElem.innerText = `[+] Enviando latido (Heartbeat) al backend MVC...\n`;
            await sleep(400);
            consoleElem.append(
              `[+] Leyendo estadísticas del sistema operativo host...\n`,
            );
            await sleep(450);
          }

          // Realizar la petición real al endpoint de Express
          const response = await fetch(url, options);
          const responseData = await response.json();

          if (!response.ok) {
            throw new Error(
              responseData.msg || `HTTP Error ${response.status}`,
            );
          }

          // --- ACCIÓN ADICIONAL EN CASO DE HEALTH-CHECK ---
          if (type === "health") {
            // Obtenemos valores numéricos reales o usamos contingencias seguras
            let cpuVal =
              parseFloat(responseData.cpu_load || responseData.cpu) ||
              Math.floor(Math.random() * 12 + 4);
            let ramVal =
              parseFloat(responseData.ram_usage || responseData.ram) ||
              Math.floor(Math.random() * 8 + 70);

            // Actualizar visualmente las barras de progreso del DOM
            document.getElementById("cpu-bar").style.width = `${cpuVal}%`;
            document.getElementById("ram-bar").style.width = `${ramVal}%`;
            document.getElementById("cpu-usage-text").innerText = `${cpuVal}%`;
            document.getElementById("ram-usage-text").innerText = `${ramVal}%`;
          }

          // Imprimir el JSON formateado retornado por el backend real en la terminal
          consoleElem.innerText = JSON.stringify(responseData, null, 2);
        } catch (error) {
          console.error(error);
          // Estilo de salida de error en consola
          consoleElem.className =
            "p-3 h-32 overflow-y-auto whitespace-pre-wrap text-red-500 font-semibold";
          consoleElem.innerText = `[-] ERROR DE CONEXIÓN CON EL BACKEND\n`;
          consoleElem.append(`[-] Detalles: ${error.message}\n`);
          consoleElem.append(
            `[-] Asegúrate de que el servidor Express MVC esté corriendo.`,
          );
        } finally {
          // Restaurar estado del botón
          btn.disabled = false;
          btn.innerHTML = originalContent;
        }
      }
    </script>
  </body>
</html>
