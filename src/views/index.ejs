    <%- include('partials/terminal') %>
    <section
      id="servicios-api"
      class="py-24 bg-[#030712] border-b border-slate-900/80 text-white"
    >
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4" data-aos="fade-up">
            Servicios de API Disponibles (MVC Real)
          </h2>
          <p
            class="text-slate-400 text-sm max-w-2xl mx-auto"
            data-aos="fade-up"
            data-aos-delay="100"
          >
            Prueba estos endpoints interconectados con las rutas, controladores
            y modelos Express de nuestra arquitectura MVC.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div
            class="card-3d card-neon-cyan bg-slate-900/40 p-6 rounded-2xl flex flex-col justify-between hover:border-cyan-500/30 transition-all duration-300"
            data-aos="fade-up"
            data-aos-delay="100"
          >
            <div>
              <div class="flex items-center justify-between mb-4">
                <span
                  class="px-2 py-1 bg-cyan-500/10 text-cyan-400 text-[10px] font-bold rounded-md border border-cyan-500/20"
                  >POST</span
                >
                <span class="text-xs font-mono text-slate-500"
                  >/api/v1/scan</span
                >
              </div>
              <h3 class="text-base font-bold text-slate-200 mb-2">
                Security Port Scanner
              </h3>
              <p class="text-xs text-slate-400 mb-6 leading-relaxed">
                Analiza hosts remotos en busca de puertos vulnerables y
                configuraciones inseguras de red.
              </p>

              <div class="space-y-2 mb-6">
                <label
                  class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider"
                  >Host de Destino</label
                >
                <input
                  id="scan-host"
                  type="text"
                  value="192.168.1.1"
                  class="w-full bg-slate-950/80 border border-slate-800 rounded-xl px-3 py-2 text-xs text-cyan-400 font-mono focus:outline-none focus:border-cyan-500/50 transition"
                />
              </div>
            </div>

            <div>
              <button
                onclick="testAPI('scan', this)"
                class="w-full bg-slate-950 hover:bg-slate-900 border border-slate-800 text-cyan-400 hover:text-cyan-300 font-semibold text-xs py-2.5 px-4 rounded-xl transition-all duration-300 flex items-center justify-center gap-2 shadow-inner"
              >
                <i class="fa-solid fa-terminal"></i> Probar EndPoint
              </button>

              <div
                id="res-container-scan"
                class="mt-4 rounded-xl overflow-hidden border border-slate-900 bg-slate-950/90 font-mono text-[10px] leading-relaxed hidden transition-all duration-300"
              >
                <div
                  class="bg-slate-900/50 px-3 py-1.5 border-b border-slate-900/80 flex justify-between items-center"
                >
                  <div class="flex gap-1">
                    <span class="w-2 h-2 rounded-full bg-red-500/60"></span>
                    <span class="w-2 h-2 rounded-full bg-yellow-500/60"></span>
                    <span class="w-2 h-2 rounded-full bg-green-500/60"></span>
                  </div>
                  <button
                    onclick="copyConsole('res-scan')"
                    class="text-slate-600 hover:text-cyan-400 transition text-[9px]"
                  >
                    <i class="fa-regular fa-copy"></i>
                  </button>
                </div>
                <pre
                  id="res-scan"
                  class="p-3 h-32 overflow-y-auto whitespace-pre-wrap text-cyan-400/90"
                ></pre>
              </div>
            </div>
          </div>

          <div
            class="card-3d card-neon-indigo bg-slate-900/40 p-6 rounded-2xl flex flex-col justify-between hover:border-indigo-500/30 transition-all duration-300"
            data-aos="fade-up"
            data-aos-delay="200"
          >
            <div>
              <div class="flex items-center justify-between mb-4">
                <span
                  class="px-2 py-1 bg-indigo-500/10 text-indigo-400 text-[10px] font-bold rounded-md border border-indigo-500/20"
                  >POST</span
                >
                <span class="text-xs font-mono text-slate-500"
                  >/api/v1/auth/token</span
                >
              </div>
              <h3 class="text-base font-bold text-slate-200 mb-2">
                Secure Auth Token Generator
              </h3>
              <p class="text-xs text-slate-400 mb-6 leading-relaxed">
                Genera JSON Web Tokens firmados criptográficamente para
                autenticar clientes de forma segura.
              </p>

              <div class="space-y-2 mb-6">
                <label
                  class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider"
                  >Rol de Acceso</label
                >
                <select
                  id="token-role"
                  class="w-full bg-slate-950/80 border border-slate-800 rounded-xl px-3 py-2 text-xs text-indigo-400 font-mono focus:outline-none focus:border-indigo-500/50 transition cursor-pointer appearance-none"
                >
                  <option value="SecOps-Admin">SecOps-Admin</option>
                  <option value="Pentester">Pentester</option>
                  <option value="Sec-Analyst">Sec-Analyst</option>
                </select>
              </div>
            </div>

            <div>
              <button
                onclick="testAPI('auth', this)"
                class="w-full bg-slate-950 hover:bg-slate-900 border border-slate-800 text-indigo-400 hover:text-indigo-300 font-semibold text-xs py-2.5 px-4 rounded-xl transition-all duration-300 flex items-center justify-center gap-2 shadow-inner"
              >
                <i class="fa-solid fa-key"></i> Probar EndPoint
              </button>

              <div
                id="res-container-auth"
                class="mt-4 rounded-xl overflow-hidden border border-slate-900 bg-slate-950/90 font-mono text-[10px] leading-relaxed hidden transition-all duration-300"
              >
                <div
                  class="bg-slate-900/50 px-3 py-1.5 border-b border-slate-900/80 flex justify-between items-center"
                >
                  <div class="flex gap-1">
