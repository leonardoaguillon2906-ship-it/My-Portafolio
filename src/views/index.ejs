    >
      <div
        class="max-w-7xl mx-auto px-6 py-3 flex justify-between items-center"
      >
        <!-- Contenedor del Logo (Manteniendo tu logo optimizado) -->
        <a href="#" class="flex items-center gap-2 group">
          <img
            src="/Galleryit_20260716_1784233800.png"
